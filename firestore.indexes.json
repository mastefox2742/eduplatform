{
  "indexes": [
    // ── Sous-collections schools/{schoolId}/* ───────────────────────────────
    {
      "collectionGroup": "students",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "classId",      "order": "ASCENDING" },
        { "fieldPath": "displayName",  "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "assessments",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "teacherId",     "order": "ASCENDING" },
        { "fieldPath": "scheduledDate", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "assessments",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "trimester",     "order": "ASCENDING" },
        { "fieldPath": "scheduledDate", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "assessments",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "status",        "order": "ASCENDING" },
        { "fieldPath": "submittedAt",   "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "attendance",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "date",        "order": "ASCENDING" },
        { "fieldPath": "teacherName", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "attendance",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "teacherId", "order": "ASCENDING" },
        { "fieldPath": "date",      "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "schedule",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "teacherId",  "order": "ASCENDING" },
        { "fieldPath": "day",        "order": "ASCENDING" },
        { "fieldPath": "startTime",  "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "schedule",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "classId",    "order": "ASCENDING" },
        { "fieldPath": "day",        "order": "ASCENDING" },
        { "fieldPath": "startTime",  "order": "ASCENDING" }
      ]
    },
    // ── Collections racine (legacy) ─────────────────────────────────────────
    {
      "collectionGroup": "students",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "schoolId", "order": "ASCENDING" },
        { "fieldPath": "classeId", "order": "ASCENDING" },
        { "fieldPath": "isActive", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "courses",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "schoolId", "order": "ASCENDING" },
        { "fieldPath": "isPublished", "order": "ASCENDING" },
        { "fieldPath": "teacherId", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "courses",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "teacherId", "order": "ASCENDING" },
        { "fieldPath": "classeIds", "arrayConfig": "CONTAINS" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "recipientUid", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "expiresAt", "order": "ASCENDING" },
        { "fieldPath": "isRead", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "auditLogs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "schoolId", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "auditLogs",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "schoolId", "order": "ASCENDING" },
        { "fieldPath": "actorUid", "order": "ASCENDING" },
        { "fieldPath": "timestamp", "order": "DESCENDING" }
      ]
    },
    {
      "collectionGroup": "_deletionQueue",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "scheduledFor", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
