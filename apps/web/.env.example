# ═══════════════════════════════════════════════════════════
# EduPlatform — Variables d'environnement Firebase
# ═══════════════════════════════════════════════════════════
#
# INSTRUCTIONS :
# 1. Copiez ce fichier en .env.local (ou .env)
# 2. Récupérez vos valeurs sur https://console.firebase.google.com
#    → Sélectionnez votre projet → Paramètres → Vos applications → Webapp
# 3. NE committez JAMAIS le fichier .env (il est dans .gitignore)
#
# ─── Firebase Config ─────────────────────────────────────────
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ─── Mode démo (désactiver en production) ─────────────────────
# Mettre à true UNIQUEMENT avec les émulateurs Firebase locaux.
# En production, laisser à false ou ne pas définir la variable.
VITE_ALLOW_DEMO_MODE=false

# ─── Optionnel ────────────────────────────────────────────────
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_GEMINI_API_KEY=
